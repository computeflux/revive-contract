{
  "name": "model-marketplace-solidity",
  "version": "1.0.0",
  "description": "AI Model Marketplace Smart Contracts - Polkadot Hub",
  "scripts": {
    "compile": "npx hardhat compile --config hardhat.config.polkadot.js",
    "test": "npx hardhat test --config hardhat.config.polkadot.js",
    "test:gas": "REPORT_GAS=true npx hardhat test --config hardhat.config.polkadot.js",
    "deploy": "npx hardhat run hack/deploy_subnet_token.js --config hardhat.config.polkadot.js --network polkadotTestnet",
    "deploy:erc20": "npx hardhat run hack/deploy_erc20.js --config hardhat.config.polkadot.js --network polkadotTestnet",
    "upgrade": "npx hardhat run hack/upgrade_subnet_token.js --config hardhat.config.polkadot.js --network polkadotTestnet",
    "node": "npx hardhat node --config hardhat.config.polkadot.js",
    "clean": "npx hardhat clean --config hardhat.config.polkadot.js"
  },
  "keywords": [
    "solidity",
    "polkadot",
    "hardhat",
    "smart-contracts",
    "marketplace"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.1.2",
    "@nomicfoundation/hardhat-ethers": "^3.1.3",
    "@nomicfoundation/hardhat-ignition": "^0.15.16",
    "@nomicfoundation/hardhat-ignition-ethers": "^0.15.17",
    "@nomicfoundation/hardhat-network-helpers": "^1.1.2",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@nomicfoundation/hardhat-verify": "^2.0.0",
    "@nomicfoundation/ignition-core": "^0.15.15",
    "@polkadot/util-crypto": "^14.0.3",
    "@typechain/ethers-v6": "^0.5.1",
    "@typechain/hardhat": "^9.1.0",
    "@types/chai": "^4.3.20",
    "@types/mocha": "^10.0.10",
    "chai": "^4.5.0",
    "hardhat": "^2.22.0",
    "hardhat-gas-reporter": "^1.0.10",
    "solidity-coverage": "^0.8.17",
    "ts-node": "^10.9.2",
    "typechain": "^8.3.2",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^4.9.6",
    "@openzeppelin/contracts-upgradeable": "^4.9.6",
    "dotenv": "^16.4.0",
    "ethers": "^6.11.0"
  }
}
