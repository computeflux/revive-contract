# Polkadot Hub 测试网配置
# 获取测试网代币: https://faucet.polkadot.io/

# 你的私钥（不要分享！）
PRIVATE_KEY=your_private_key_here

# Polkadot Hub 测试网 RPC（可选，已有默认值）
POLKADOT_TESTNET_RPC_URL=https://services.polkadothub-rpc.com/testnet

# Ethereum Sepolia 测试网配置（可选）
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/your_infura_key

# Ethereum 主网配置（可选）
MAINNET_RPC_URL=https://mainnet.infura.io/v3/your_infura_key

# Etherscan API Key（用于合约验证，Polkadot 不需要）
ETHERSCAN_API_KEY=your_etherscan_api_key

# Gas 报告（可选）
REPORT_GAS=true

# tee-provider ECDSA 私钥 (secp256k1, 64 hex chars)
ECDSA_KEY=your_ecdsa_private_key_here
